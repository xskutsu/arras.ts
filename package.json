{
	"name": "arras.ts",
	"version": "0.0.0",
	"description": "A fanmade sequel to diep.io, this time in TypeScript",
	"license": "LGPL-3.0-or-later",
	"repository": {
		"type": "git",
		"url": "https://github.com/xskutsu/arras.ts"
	},
	"homepage": "https://github.com/xskutsu/arras.ts#readme",
	"bugs": {
		"url": "https://github.com/xskutsu/arras.ts/issues"
	},
	"private": false,
	"type": "module",
	"engines": {
		"node": ">=24.0.0"
	},
	"packageManager": "pnpm@10.31.0",
	"scripts": {
		"start": "node dist/server.js",
		"build": "node scripts/esbuild.mjs",
		"watch": "node scripts/esbuild.mjs --watch",
		"serve": "node scripts/serve.mjs",
		"check": "tsc -p tsconfig.json --noEmit",
		"clean": "node scripts/clean.mjs"
	},
	"dependencies": {
		"uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.59.0"
	},
	"devDependencies": {
		"@types/node": "^25.4.0",
		"esbuild": "^0.27.3",
		"typescript": "^5.9.3"
	}
}
